<div class="px-4 sm:px-0">
  <h3 class="text-base/7 font-semibold text-gray-900">Rollout Percentage</h3>
  <p class="mt-1 text-sm/6 text-gray-600">Gradually roll out this setting's alternate value to a percentage of scopes</p>
</div>

<div class="bg-white shadow-xs outline outline-gray-900/5 sm:rounded-xl md:col-span-2">
  <div class="px-4 py-6 sm:p-6">
    <% if setting.experiment == nil %>
      <div class="text-center py-6" id="rollout-setup">
        <p class="text-sm text-gray-500 mb-4">No rollout configured</p>
        <%= button_tag "Set Up", type: "button", id: "setup-rollout", class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" %>
      </div>
    <% end %>

    <% rollout_percentage = setting.experiment&.variants&.dig(1)&.percentage&.to_i || 0 %>

    <div id="rollout-content" class="<%= 'hidden' if setting.experiment == nil %>">
      <div class="flex flex-col gap-6">
        <div class="flex items-center gap-3">
          <div class="group relative inline-flex w-11 shrink-0 rounded-full bg-gray-200 p-0.5 inset-ring inset-ring-gray-900/5 outline-offset-2 transition-colors duration-200 ease-in-out has-checked:bg-indigo-600 opacity-60">
            <span class="size-5 rounded-full bg-white shadow-xs ring-1 ring-gray-900/5 transition-transform duration-200 ease-in-out group-has-checked:translate-x-5"></span>
            <input type="checkbox" id="rollout-toggle" class="absolute inset-0 appearance-none focus:outline-hidden" disabled
                   <%= 'checked' unless setting.value %> />
          </div>
          <div class="text-sm/6">
            <span class="font-medium text-gray-500">Rollout value</span>
            <p class="text-gray-400">Automatically set to the opposite of the global value</p>
          </div>
        </div>

        <div>
          <div class="flex items-center justify-between">
            <label for="rollout-percentage" class="block text-sm/6 font-medium text-gray-900">Percentage</label>
            <span id="rollout-percentage-display" class="text-sm font-semibold text-indigo-600"><%= rollout_percentage %>%</span>
          </div>
          <div class="mt-2">
            <input type="range" name="variants[1][percentage]" id="rollout-percentage" min="0" max="100" value="<%= rollout_percentage %>"
                   class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-indigo-600" />
          </div>
          <div class="mt-1 flex justify-between text-xs text-gray-400">
            <span>0%</span>
            <span>100%</span>
          </div>
        </div>
      </div>

      <input type="hidden" name="variants[1][value]" id="rollout-value" value="<%= setting.value ? '0' : '1' %>" />
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var setupButton = document.getElementById('setup-rollout');
  var rolloutSetup = document.getElementById('rollout-setup');
  var rolloutContent = document.getElementById('rollout-content');
  var rolloutSlider = document.getElementById('rollout-percentage');
  var rolloutDisplay = document.getElementById('rollout-percentage-display');
  var rolloutToggle = document.getElementById('rollout-toggle');
  var rolloutValue = document.getElementById('rollout-value');
  var globalCheckbox = document.getElementById('value');

  if (setupButton) {
    setupButton.addEventListener('click', function() {
      rolloutSetup.style.display = 'none';
      rolloutContent.classList.remove('hidden');
    });
  }

  if (rolloutSlider) {
    rolloutSlider.addEventListener('input', function() {
      rolloutDisplay.textContent = this.value + '%';
    });
  }

  if (globalCheckbox) {
    globalCheckbox.addEventListener('change', function() {
      var globalIsTrue = this.checked;
      rolloutToggle.checked = !globalIsTrue;
      rolloutValue.value = globalIsTrue ? '0' : '1';
    });
  }
});
</script>
